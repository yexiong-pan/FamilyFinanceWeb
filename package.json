{
  "name": "family-finance-web-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @family-finance/api\" \"npm run dev -w @family-finance/web\"",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "dev:api": "npm run dev -w @family-finance/api",
    "dev:web": "npm run dev -w @family-finance/web",
    "nas:config": "docker compose -p family-finance-nas -f docker-compose.yml config",
    "nas:build": "docker compose -p family-finance-nas -f docker-compose.yml build",
    "nas:up": "docker compose -p family-finance-nas -f docker-compose.yml up -d --build",
    "nas:down": "docker compose -p family-finance-nas -f docker-compose.yml down",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run prisma:generate -w @family-finance/api",
    "db:migrate": "npm run prisma:migrate -w @family-finance/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
