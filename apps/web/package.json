{
  "name": "@family-finance/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prebuild": "npm run build -w @family-finance/shared",
    "predev": "npm run build -w @family-finance/shared",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview",
    "build": "tsc -p tsconfig.json && vite build",
    "pretest": "npm run build -w @family-finance/shared",
    "test": "vitest run",
    "pretypecheck": "npm run build -w @family-finance/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ant-design/charts": "^2.0.0",
    "@ant-design/icons": "^6.2.5",
    "@family-finance/shared": "0.1.0",
    "@vitejs/plugin-react": "^4.0.0",
    "antd": "^6.4.5",
    "antd-style": "^4.1.0",
    "dayjs": "^1.11.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0"
  }
}
