{
  "name": "@family-finance/api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "prebuild": "npm run build -w @family-finance/shared",
    "predev": "npm run build -w @family-finance/shared",
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "pretest": "npm run build -w @family-finance/shared",
    "test": "vitest run",
    "pretypecheck": "npm run build -w @family-finance/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@family-finance/shared": "0.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^24.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.20.3"
  }
}
